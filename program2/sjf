#include <stdio.h>
#define max 10

struct process
{
    int at,bt,wt,tat,ct,done;
};

int main()
{
    struct process p[max];
    int n,current_time=0,completed=0;
    float avgwt=0,avgtat=0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++)
    {
        printf("\nProcess %d\n",i);

        printf("Arrival time: ");
        scanf("%d",&p[i].at);

        printf("Burst time: ");
        scanf("%d",&p[i].bt);

        p[i].done=0;
    }

    while(completed < n)
    {
        int idx=-1,minbt=999;

        for(int i=0;i<n;i++)
        {
            if(p[i].at<=current_time && p[i].done==0 && p[i].bt<minbt)
            {
                minbt=p[i].bt;
                idx=i;
            }
        }

        if(idx!=-1)
        {
            p[idx].ct=current_time+p[idx].bt;
            p[idx].tat=p[idx].ct-p[idx].at;
            p[idx].wt=p[idx].tat-p[idx].bt;

            avgwt+=p[idx].wt;
            avgtat+=p[idx].tat;

            p[idx].done=1;
            completed++;

            current_time=p[idx].ct;
        }
        else
        {
            current_time++;
        }
    }

    printf("\nID\tAT\tBT\tCT\tWT\tTAT\n");

    for(int i=0;i<n;i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
        i,p[i].at,p[i].bt,p[i].ct,p[i].wt,p[i].tat);
    }

    printf("\nAverage WT = %.2f",avgwt/n);
    printf("\nAverage TAT = %.2f",avgtat/n);

    return 0;
}

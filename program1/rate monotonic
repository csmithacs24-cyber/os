#include <stdio.h>
#include <math.h>

#define MAX 10

int gcd(int a, int b)
{
    while (b != 0)
    {
        int t = b;
        b = a % b;
        a = t;
    }
    return a;
}

int lcm(int a, int b)
{
    return (a * b) / gcd(a, b);
}

int find_lcm(int arr[], int n)
{
    int res = arr[0];

    for (int i = 1; i < n; i++)
    {
        res = lcm(res, arr[i]);
    }

    return res;
}

int main()
{
    int n;
    int execution[MAX], period[MAX], deadline[MAX];
    int remaining[MAX] = {0};

    float utilization = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++)
    {
        printf("\nProcess P%d\n", i + 1);

        printf("Enter Execution Time: ");
        scanf("%d", &execution[i]);

        printf("Enter Period: ");
        scanf("%d", &period[i]);

        printf("Enter Deadline: ");
        scanf("%d", &deadline[i]);
    }

    int hyper = find_lcm(period, n);

    printf("\nLCM = %d\n", hyper);

    printf("\nRate Monotonic Scheduling\n");

    printf("\nProcess\tExecution\tPeriod\tDeadline\n");

    for (int i = 0; i < n; i++)
    {
        printf("P%d\t%d\t\t%d\t%d\n",
               i + 1,
               execution[i],
               period[i],
               deadline[i]);

        utilization += (float)execution[i] / period[i];
    }

    float bound = n * (pow(2, 1.0 / n) - 1);

    printf("\nCPU Utilization = %.2f%%\n", utilization * 100);
    printf("RMS Bound = %.2f%%\n", bound * 100);

    if (utilization <= bound)
        printf("Scheduling is Possible\n");
    else
        printf("Scheduling is Not Possible\n");

    printf("\nScheduling occurs for %d ms\n\n", hyper);

    int last = -1;

    for (int t = 0; t < hyper; t++)
    {
    
        for (int i = 0; i < n; i++)
        {
            if (t % period[i] == 0)
            {
                remaining[i] = execution[i];
            }
        }

        int selected = -1;

        
        for (int i = 0; i < n; i++)
        {
            if (remaining[i] > 0)
            {
                if (selected == -1 ||
                    period[i] < period[selected])
                {
                    selected = i;
                }
            }
        }

        
        if (selected != last)
        {
            if (selected != -1)
                printf("%d ms onwards : Process P%d running\n",
                       t, selected + 1);
            else
                printf("%d ms onwards : CPU Idle\n", t);

            last = selected;
        }

        
        if (selected != -1)
        {
            remaining[selected]--;
        }
    }

    return 0;
